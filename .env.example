# Copy this to .env and fill in your actual keys

# API Keys
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TWELVE_DATA_API_KEY=your_twelvedata_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# Database
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=quantum_trader

# Server Configuration
PORT=8000
ENVIRONMENT=production
DEBUG=false

# Security
JWT_SECRET=your_jwt_secret
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=1000

# Trading Parameters
MAX_TRADE_SIZE=100000
MAX_POSITIONS=10
MAX_LEVERAGE=5

# AI Configuration
MODEL_CACHE_DIR=/tmp/quantum_ai_models
MAX_MODEL_MEMORY=4096

# Monitoring
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=INFO

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENV=production

# Cache
CACHE_TTL=3600
REDIS_CACHE_PREFIX=quantum_trader:

# Broker Configuration
BROKER_TIMEOUT=30
BROKER_RETRY_DELAY=5

# Strategy Parameters
MIN_CONFIDENCE=0.7
MAX_RISK_PER_TRADE=0.01

# Health Check
HEALTH_CHECK_INTERVAL=60
MAX_LATENCY_MS=500

# Feature Flags
ENABLE_STRATEGY_FUSION=true
ENABLE_SECTOR_ANALYSIS=true
ENABLE_LIQUIDATION_DETECTION=true
ENABLE_MARKET_SIMULATION=true
