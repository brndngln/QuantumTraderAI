# Project Information
PROJECT_NAME           = "QuantumTraderAI"
OUTPUT_DIRECTORY       = docs
RECURSIVE              = YES
INPUT                  = ./
FILE_PATTERNS          = *.py *.md *.txt
EXTRACT_ALL            = YES
OPTIMIZE_OUTPUT_FOR_PYTHON = YES

# Markdown Integration
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = README.md

# Output Control
GENERATE_HTML          = NO
GENERATE_LATEX         = YES
GENERATE_RTF           = NO
GENERATE_XML           = NO

# LaTeX for PDF
PDF_HYPERLINKS         = YES
GENERATE_TREEVIEW      = YES
LATEX_BATCHMODE        = YES
LATEX_SOURCE_CODE      = YES
EXTRA_PACKAGES         = amsmath

# Warnings
WARN_IF_UNDOCUMENTED   = YES

# Misc
INPUT_ENCODING         = UTF-8