    },
    "alert_channels": ["email", "slack", "discord"],
    "alert_webhook_urls": {
        "slack": "",
        "discord": ""
    },
    "smtp_config": {
        "host": "smtp.example.com",
        "port": "587",
        "user": "",
        "password": ""
    },
    "visualization_interval": 60,
    "visualization_types": ["topology", "traffic", "performance"]
