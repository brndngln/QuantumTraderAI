{
  "version": 2,
  "builds": [
    {
      "src": "frontend/index.html",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REDIS_URL": "@redis_url",
    "DATABASE_URL": "@database_url",
    "API_KEY": "@api_key",
    "SECRET_KEY": "@secret_key",
    "ENVIRONMENT": "production",
    "DEBUG": "false",
    "CELERY_BROKER_URL": "@redis_url",
    "CELERY_RESULT_BACKEND": "@redis_url",
    "REACT_APP_API_URL": "https://api.quantum-trader.com",
    "REACT_APP_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.quantum-trader.com/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://quantum-trader.vercel.app"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,PUT,DELETE,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type,Authorization,X-Requested-With"
        }
      ]
    }
  ],
  "functions": {
    "api/**": {
      "memory": 2048,
      "maxDuration": 30
    }
  },
  "github": {
    "enabled": true,
    "autoDeploy": true
  },
  "analytics": {
    "enabled": true
  },
  "featureFlags": {
    "strategyFusion": true,
    "sectorAnalysis": true,
    "liquidationDetection": true,
    "marketSimulation": true
  },
  "security": {
    "rateLimit": {
      "window": 60,
      "max": 1000
    }
  },
  "errorPages": {
    "404": "/404.html",
    "500": "/500.html"
  }
}